# =============================================================================
# AMSETS API - Environment Template (Production/Mainnet)
# Copy this file to .env and fill all placeholders.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://amsets:CHANGE_ME_PASSWORD@127.0.0.1:5432/amsets_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=180d

# ─── Solana (Mainnet) ─────────────────────────────────────────────────────────
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=CHANGE_ME_HELIUS_API_KEY
HELIUS_API_KEY=CHANGE_ME_HELIUS_API_KEY
PROGRAM_ID=CHANGE_ME_MAINNET_PROGRAM_ID

# Optional webhook secret if you use Helius webhooks
HELIUS_WEBHOOK_SECRET=CHANGE_ME_OPTIONAL

# ─── Storage / Media ──────────────────────────────────────────────────────────
PINATA_JWT=CHANGE_ME_PINATA_JWT
PINATA_GATEWAY=https://gateway.pinata.cloud
LIVEPEER_API_KEY=CHANGE_ME_LIVEPEER_API_KEY
LIVEPEER_SIGNING_KEY_ID=CHANGE_ME_LIVEPEER_SIGNING_KEY_ID
LIVEPEER_PRIVATE_KEY=CHANGE_ME_BASE64_PRIVATE_KEY

# ─── Mint / Withdraw Authorities ──────────────────────────────────────────────
# Mint authority private key in base58 format (server-side only)
MINT_AUTHORITY_SECRET=CHANGE_ME_BASE58_SECRET_KEY

# Optional explicit mint authority pubkey override
MINT_AUTHORITY_PUBKEY=CHANGE_ME_OPTIONAL_PUBKEY

# Withdraw authority can be:
# 1) path to keypair JSON file (recommended), or
# 2) base58 secret key
WITHDRAW_AUTHORITY_KEYPAIR=/opt/amsets/keys/upgrade-authority.json

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# NOTE: backend currently reads this fallback in admin route; keep equal to PROGRAM_ID
NEXT_PUBLIC_PROGRAM_ID=CHANGE_ME_MAINNET_PROGRAM_ID

# ─── Optional / Legacy ────────────────────────────────────────────────────────
# Kept for compatibility if referenced elsewhere
LIT_NETWORK=datil
