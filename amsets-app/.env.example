# =============================================================================
# AMSETS APP (Next.js) - Environment Template (Production/Mainnet)
# Copy this file to .env.local for local run, or set as env vars in Vercel.
# =============================================================================

# ─── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.example.com

# ─── Solana (Mainnet) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=CHANGE_ME_HELIUS_API_KEY
NEXT_PUBLIC_PROGRAM_ID=CHANGE_ME_MAINNET_PROGRAM_ID

# ─── Web3Auth ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=CHANGE_ME_WEB3AUTH_CLIENT_ID

# ─── Lit Protocol ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_LIT_NETWORK=datil

# ─── Pinata / IPFS (public client-side usage in current app design) ──────────
NEXT_PUBLIC_PINATA_JWT=CHANGE_ME_PINATA_JWT
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── Arweave / Irys ───────────────────────────────────────────────────────────
NEXT_PUBLIC_IRYS_NETWORK=mainnet
NEXT_PUBLIC_ARWEAVE_GATEWAY=https://arweave.net

# ─── Mint Authority Public Key (public only, no private key) ─────────────────
NEXT_PUBLIC_MINT_AUTHORITY_PUBKEY=CHANGE_ME_MINT_AUTHORITY_PUBKEY
